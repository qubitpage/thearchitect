# The Architect — Environment Configuration
# Copy to .env.local for local development. Never commit real credentials.

NEXT_PUBLIC_APP_NAME="The Architect"

# PostgreSQL Connection
DB_HOST=localhost
DB_PORT=5432
DB_NAME=the_architect
DB_USER=postgres
DB_PASSWORD=

# Optional: Full connection string (overrides individual fields above)
# DATABASE_URL=postgresql://postgres:<db_password>@localhost:5432/the_architect

# Google Gemini API Key (optional — demo mode used when not set)
# GEMINI_API_KEY=

# Platform Auth (optional — defaults to 'citizen' role if not set)
# PLATFORM_ROLE=federation_admin